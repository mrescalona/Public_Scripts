### We performed mapping with paleomix and the follwoing parameters at the .yaml
# Commented lines and not shown parameters

# Settings for trimming of reads, see AdapterRemoval man-page
  AdapterRemoval:
     --mm: 3
     --minlength: 25
     --collapse: yes
     --trimns: yes
     --trimqualities: yes

# Settings for aligners supported by the pipeline
  Aligners:
    # Choice of aligner software to use, either "BWA" or "Bowtie2"
    Program: BWA

    # Settings for mappings performed using BWA
    BWA:
      Algorithm: mem
      MinQuality: 0
      # Filter reads that did not map to the reference sequence
      FilterUnmappedReads: yes
      UseSeed: yes

 # Set to 'yes' exclude a type of trimmed reads from alignment / analysis;
  # possible read-types reflect the output of AdapterRemoval
  ExcludeReads:
    # Exclude single-end reads (yes / no)?
    Single: no
    # Exclude non-collapsed paired-end reads (yes / no)?
    Paired: no
    # Exclude paired-end reads for which the mate was discarded (yes / no)?
    Singleton: no
    # Exclude overlapping paired-ended reads collapsed into a single sequence
    # by AdapterRemoval (yes / no)?
    Collapsed: no
    # Like 'Collapsed', but only for collapsed reads truncated due to the
    # presence of ambiguous or low quality bases at read termini (yes / no).
    CollapsedTruncated: no

  # Optional steps to perform during processing.
  Features:
    # If set to 'filter', PCR duplicates are removed from the output files; if set to
    # 'mark', PCR duplicates are flagged with bit 0x400, and not removed from the
    # output files; if set to 'no', the reads are assumed to not have been amplified.
    PCRDuplicates: filter
    # Set to 'no' to disable mapDamage; set to 'plots' to build basic mapDamage plots;
    # set to 'model' to build plots and post-mortem damage models; and set to 'rescale'
    # to build plots, models, and BAMs with rescaled quality scores. All analyses are
    # carried out per library.
    mapDamage: no
    # Generate coverage information for the final BAM and for each 'RegionsOfInterest'
    # specified in 'Prefixes' (yes / no).
    Coverage: yes
    # Generate histograms of number of sites with a given read-depth, from 0 to 200,
    # for each BAM and for each 'RegionsOfInterest' specified in 'Prefixes' (yes / no).
    Depths: yes
    # Generate summary table for each target (yes / no)
    Summary: yes


#############################
# After mapping with Paleomix, BAM files were processed with GATK to make gVCFs for each sample and posterior "merging" into a single VCF
#############################

#For each sample, the basic workflow was as follow:

~/software/gatk-4.6.2.0/gatk HaplotypeCaller -I input.bam -O output.g.vcf.gz -R reference.fasta --tmp-dir ./gatk_temp -ERC GVCF --native-pair-hmm-threads 8

~/software/gatk-4.6.2.0/gatk GenomicsDBImport --genomicsdb-workspace-path /media/labgenoma5/slbonatto_20b/tursiops/02_vcf/DB \
    --batch-size 10 --sample-name-map DB_mapfile.txt --intervals /media/labgenoma5/slbonatto_20b/tursiops/02_vcf/Tursiops_truncatus.intervals \
    --tmp-dir /media/labgenoma5/slbonatto_20b/tursiops/02_vcf/temp

~/software/gatk-4.6.2.0/gatk GenotypeGVCFs --output /media/labgenoma5/slbonatto_20b/tursiops/02_vcf/tursiops_raw_population.vcf.gz \
    --variant gendb:///media/labgenoma5/slbonatto_20b/tursiops/02_vcf/DB --reference /media/labgenoma5/slbonatto_20b/references/tursiops/ref_with_mito/GCA_011762595.2_mTurTru1.mat.Y_genomic.fasta \
    --include-non-variant-sites false --sample-ploidy 2 \
    --standard-min-confidence-threshold-for-calling 30.0


### Update DB
# 2 samples were sequenced later in 2026
# Instead of recreating the DB, we updated the DB and only recreated the final VCF
# Updated DB used the following command

~/software/gatk-4.6.2.0/gatk GenomicsDBImport -genomicsdb-update-workspace-path /media/labgenoma5/slbonatto_20b/tursiops/02_vcf/DB \
    --batch-size 10 --sample-name-map DB_mapfile_2026.txt --intervals /media/labgenoma5/slbonatto_20b/tursiops/02_vcf/Tursiops_truncatus.intervals \
    --tmp-dir /media/labgenoma5/slbonatto_20b/tursiops/02_vcf/temp

####################################################
# Parallel example to run multiple samples together
####################################################

parallel -j 2 --progress --joblog gatk_jobs.log \
"mkdir -p /media/labgenoma5/slbonatto_20b/tursiops/01_gvcf/gatk_temp/{#}; \
~/workspace/software/gatk-4.6.2.0/gatk HaplotypeCaller \
-I {} \
-O /media/labgenoma5/slbonatto_20b/tursiops/01_gvcf/{/}.g.vcf.gz \
-R /media/labgenoma5/slbonatto_20b/references/tursiops/ref_with_mito/GCA_011762595.2_mTurTru1.mat.Y_genomic.fasta \
--tmp-dir /media/labgenoma5/slbonatto_20b/tursiops/01_gvcf/gatk_temp/{#} \
-ERC GVCF \
--native-pair-hmm-threads 8" ::: /media/labgenoma5/slbonatto_20b/tursiops/00_paleomix/*.bam

#########################################################
# For map file and intervals, we used these bash commands
#########################################################

for f in *.g.vcf.gz; do
    sample=$(basename "$f" .bam.g.vcf.gz)
    sample=${sample/.Ttrunc/}  # remove the species suffix if present
    echo -e "${sample}\t${PWD}/${f}"
done > DB_mapfile.txt

grep ">" ../../references/megaptera/Megaptera_novaeangliae.fasta | sed 's/>//g' | awk '{print $1}' > Megaptera_novaeangliae.intervals

