# To create the PCA, we first run plink to create necessary files and run PCA
# Plot is done via R

plink --vcf ../02_vcf/tursiops_biallelic_snps.vcf.gz --double-id --allow-extra-chr --make-bed --out tursiops_biallelic_snps_pca
plink --bfile tursiops_biallelic_snps_pca --pca 20 --out tursiops_biallelic_snps_pca --allow-extra-chr
plink --bfile tursiops_biallelic_snps_pca --distance square 1-ibs --out tursiops_biallelic_snps_pca --allow-extra-chr

# Commands to go from VCF to Admixture, using PLINK as intermediate

plink --vcf ../02_vcf/tursiops_biallelic_snps.vcf.gz --double-id --allow-extra-chr --make-bed --out tursiops_biallelic_snps

plink   --bfile tursiops_biallelic_snps   --set-missing-var-ids @:#:\$1:\$2   --make-bed   --allow-extra-chr --double-id   --out tursiops_biallelic_snps_IDs
plink   --bfile tursiops_biallelic_snps_IDs   --geno 0.1 --mind 0.1 --maf 0.05   --indep-pairwise 50 5 0.1   --allow-extra-chr --double-id   --out tursiops_pruned
plink   --bfile tursiops_biallelic_snps_IDs   --extract tursiops_pruned.prune.in   --make-bed   --allow-extra-chr --double-id   --out tursiops_admixture

awk '{$1="0";print $0}' tursiops_admixture.bim > tursiops_admixture.bim.tmp
mv tursiops_admixture.bim.tmp tursiops_admixture.bim

for k in $(seq 1 10); do admixture --cv tursiops_admixture.bed $k > log${k}.out ; done
